---
import "../styles/global.css";
import { ClientRouter } from 'astro:transitions';

interface Props {
    title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="de">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Funnel+Sans:ital,wght@0,300..800;1,300..800&display=swap"
            rel="stylesheet"
        />
        <ClientRouter />
        <title>{title}</title>
    </head>
    <body style="display: flex; flex-direction: column; min-height: 100vh;">
        <header
            style="display: flex; justify-content: space-between; padding: 2rem 0; max-width: 700px; width: 100%; margin: 0 auto;"
        >
            <a href="/" style="color: var(--anthrazit-mid);">REY ALITE</a>
            <nav style="display: flex; gap: 2rem;">
                <a href="/">PROJECTS</a>
                <a href="/cv">CV</a>
                <a href="/contact">CONTACT</a>
            </nav>
        </header>

        <main style="max-width: 700px; width: 100%; margin: 0 auto; flex: 1;">
            <slot />
        </main>

        <footer
            style="max-width: 700px; width: 100%; margin: 0 auto; text-align: right; padding: 2rem 0;"
        >
            <small>© 2025</small>
        </footer>
    </body>
</html>

<style>
    a {
        color: var(--anthrazit);
        text-decoration: none;
        font-size: 1rem;
        font-weight: 400;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin:;
        transition: background-color 0.15s;
    }

    a:hover {
        background-color: var(--hell);
    }
</style>
